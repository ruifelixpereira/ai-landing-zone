# Azure Developer CLI Environment Variables
# Copy this file to .azure/<env-name>/.env and update with your values

# REQUIRED: Basic Configuration
AZURE_ENV_NAME="ai-plat-lz-dev"
CUSTOM_NAMING="rfp01"
AZURE_LOCATION="swedencentral"
AZURE_SUBSCRIPTION_ID="your-subscription-id-here"


# OPTIONAL: Resource Group
# Leave empty to use auto-generated name based on environment name
AZURE_RESOURCE_GROUP="rg-ai-plat-lz-dev"

# OPTIONAL: API Management Configuration
# Allowed values: Developer, Premium, StandardV2, PremiumV2
APIM_SKU="StandardV2"
APIM_SKU_UNITS="1"

# OPTIONAL: Feature Flags (true/false)
ENABLE_AI_FOUNDRY="true"
ENABLE_API_CENTER="true"
ENABLE_PII_REDACTION="true"
CREATE_DASHBOARDS="false"

# OPTIONAL: Capacity and SKU Settings
COSMOS_DB_RUS="400"
EVENTHUB_CAPACITY="1"
OPENAI_CAPACITY="20"

# OPTIONAL: Microsoft Entra ID Authentication
# Set AZURE_ENTRA_AUTH=true to enable
AZURE_ENTRA_AUTH="false"
AZURE_TENANT_ID=""
AZURE_CLIENT_ID=""
AZURE_AUDIENCE=""

# OPTIONAL: Bring Your Own Network (BYON)
# Set USE_EXISTING_VNET=true to use existing VNet
USE_EXISTING_VNET="false"
EXISTING_VNET_RG=""
VNET_NAME=""

# VNet address space and subnet prefixes
VNET_ADDRESS_PREFIX="10.170.0.0/24"
APIM_SUBNET_PREFIX="10.170.0.0/26"
PRIVATE_ENDPOINT_SUBNET_PREFIX="10.170.0.64/26"
FUNCTION_APP_SUBNET_PREFIX="10.170.0.128/26"

# OPTIONAL: Bring Your Own Private DNS Zones
#DNS_ZONE_RG=""
#DNS_SUBSCRIPTION_ID=""
DNS_ZONE_RG="<your-resource-group-name>"
DNS_SUBSCRIPTION_ID="<your-subscription-id>"

EXISTING_DNS_ZONE_AI_SERVICES="/subscriptions/<your-subscription-id>/resourceGroups/<your-resource-group-name>/providers/Microsoft.Network/privateDnsZones/privatelink.services.ai.azure.com"
